# Turkium API Server Configuration
# Copy this file to .env and update values as needed

# ============================================
# Server Configuration
# ============================================

# Server host (0.0.0.0 for all interfaces)
SERVER_HOST=0.0.0.0

# Server port
SERVER_PORT=3001

# Environment (development, staging, production)
ENVIRONMENT=production

# ============================================
# Turkium Node Configuration
# ============================================

# Turkium node RPC host
TURKIUM_NODE_HOST=localhost

# Turkium node RPC port
TURKIUM_NODE_PORT=5200

# Timeout for RPC calls (seconds)
TURKIUM_NODE_TIMEOUT_SECS=10

# ============================================
# Cache Configuration
# ============================================

# Cache TTL in seconds
CACHE_TTL_SECS=30

# Maximum cache capacity (number of entries)
CACHE_MAX_CAPACITY=10000

# ============================================
# CORS Configuration
# ============================================

# CORS allowed origins (comma-separated or *)
CORS_ALLOWED_ORIGINS=*

# ============================================
# Rate Limiting Configuration
# ============================================

# Rate limit requests per window
RATE_LIMIT_REQUESTS=1000

# Rate limit window in seconds
RATE_LIMIT_WINDOW_SECS=60

# ============================================
# Logging Configuration
# ============================================

# Rust log level (trace, debug, info, warn, error)
RUST_LOG=info,turkium_api_server=debug
